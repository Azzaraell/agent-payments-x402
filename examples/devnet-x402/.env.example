# Only the REAL devnet path needs these. The offline demo (`npm run demo`) and
# tests (`npm test`) need none of them.

# Your base58 Solana receiving address (must have, or auto-create, a USDC ATA).
PAYTO_SOLANA_ADDRESS=

# Devnet CAIP-2 network id (verified against @x402/svm@2.16).
X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# Testnet facilitator that covers Solana devnet. @x402/express@2.16's README uses
# this host; older docs use https://x402.org/facilitator. Keep it env-driven.
X402_FACILITATOR_URL=https://facilitator.x402.org

# base58 secret key of the PAYING wallet. DEV ONLY — never a mainnet god-key.
# In production the signer is policy-gated (Squads v4 / Privy / Turnkey / CDP).
SVM_PRIVATE_KEY=
