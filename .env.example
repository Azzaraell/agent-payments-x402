# Solana Agent Payments — example env. Copy to .env and fill in.
# NEVER commit .env (it is gitignored).

# RPC — devnet first; switch to a mainnet RPC for prod.
SOLANA_RPC_URL=https://api.devnet.solana.com

# USDC mint + network. Devnet shown; flip to mainnet only after the devnet loop passes.
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU   # mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
X402_NETWORK=solana-devnet                               # or the CAIP-2 id from @x402/svm for v2

# x402 facilitator (server side). Testnet shown; prod: Coinbase CDP or PayAI.
X402_FACILITATOR_URL=https://x402.org/facilitator

# Receiving address for monetization (base58 Solana address with a USDC ATA).
PAYTO_SOLANA_ADDRESS=

# Spending controls (client side)
PER_CALL_CAP_USD=0.10        # reject any single x402 payment above this
SESSION_CAP_USD=2.00         # max total spend per agent run
PAYMENTS_ENABLED=true        # kill switch: set false to halt ALL agent spend

# Signer — DEV ONLY. On mainnet, authority must live behind a Squads v4 spending
# limit or a policy-gated signer (Privy/Turnkey/CDP/Crossmint), NOT a bare key.
# See skill/spending-controls.md.
SOLANA_PRIVATE_KEY=          # devnet keypair as JSON byte array, e.g. [12,34,...]
